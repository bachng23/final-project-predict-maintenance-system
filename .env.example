# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=predictive-maintenance-db

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=your-redis-password

# ─── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_USER=minioadmin
MINIO_PASSWORD=your-minio-password

# ─── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=your-clickhouse-password

# ─── Langfuse ──────────────────────────────────────────────────────────────────
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_SECRET=your-langfuse-secret-32chars
LANGFUSE_SALT=your-langfuse-salt
# Generate with: openssl rand -hex 32
LANGFUSE_ENCRYPTION_KEY=00000000000000000000000000000000000000000000000000000000₀₀₀₀₀₀₀₀
LANGFUSE_TELEMETRY_ENABLED=false
LANGFUSE_S3_BUCKET=langfuse
LANGFUSE_S3_REGION=auto

# ─── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-grafana-password

# ─── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_DEFAULT_MODEL=llama3.2:3b
