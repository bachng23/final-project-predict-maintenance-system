PORT=3000
HOST=127.0.0.1
NODE_ENV=development

# Database Configuration
# Use PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/predictive_maintenance?schema=public"

# JWT Configuration
# Generate random secrets for production:
# Node: require('crypto').randomBytes(32).toString('hex')
JWT_ACCESS_SECRET="your-secret-access-key-change-in-production"
JWT_REFRESH_SECRET="your-secret-refresh-key-change-in-production"

# CORS Configuration
CORS_ORIGIN="*"
