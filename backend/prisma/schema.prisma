generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Bearing {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bearing_id        String        @unique
  display_name      String
  dataset_source    String
  condition_label   String
  rpm               Int?
  load_kn           Float?
  installation_date DateTime?     @db.Timestamptz(6)
  status            BearingStatus @default(NORMAL)
  active            Boolean       @default(true)
  created_at        DateTime      @default(now()) @db.Timestamptz(6)
  updated_at        DateTime      @default(now()) @updatedAt @db.Timestamptz(6)
  predictions       Prediction[]
  snapshots         Snapshot[]

  @@map("bearings")
}

model Prediction {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bearing_id        String     @db.Uuid
  file_idx          Int
  sample_ts         DateTime   @db.Timestamptz(6)
  rul_minutes       Float
  rul_lower_minutes Float?
  rul_upper_minutes Float?
  rul_uncertainty   Float?
  p_fail            Float
  health_score      Float
  degradation_rate  Float?
  ood_flag          Boolean?
  fault_type        FaultType?
  fault_confidence  Float?
  stat_score        Float?
  rul_drop_score    Float?
  hybrid_score      Float?
  threshold_tau     Float?
  model_version     String
  pipeline_run_id   String?
  created_at        DateTime   @default(now()) @db.Timestamptz(6)
  bearing           Bearing    @relation(fields: [bearing_id], references: [id])
  snapshots         Snapshot[]

  @@unique([bearing_id, file_idx, model_version])
  @@index([bearing_id, sample_ts(sort: Desc)])
  @@index([created_at(sort: Desc)])
  @@map("predictions")
}

model Snapshot {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bearing_id         String            @db.Uuid
  prediction_id      String            @db.Uuid
  snapshot_ts        DateTime          @db.Timestamptz(6)
  status             String
  trigger_source     TriggerSource
  feature_vector_ref String?
  signal_window_ref  String?
  summary_json       Json?
  created_at         DateTime          @default(now()) @db.Timestamptz(6)
  agent_transcripts  AgentTranscript[]
  decision           Decision?
  bearing            Bearing           @relation(fields: [bearing_id], references: [id])
  prediction         Prediction        @relation(fields: [prediction_id], references: [id])

  @@index([bearing_id, snapshot_ts(sort: Desc)])
  @@map("snapshots")
}

model Decision {
  id                     String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  snapshot_id            String               @unique @db.Uuid
  decision_type          DecisionType
  recommended_action     ActionType
  recommended_confidence Float?
  decision_status        DecisionStatus       @default(PENDING)
  priority               PriorityLevel        @default(MEDIUM)
  safety_veto            Boolean              @default(false)
  reason_summary         String?
  opened_at              DateTime             @default(now()) @db.Timestamptz(6)
  resolved_at            DateTime?            @db.Timestamptz(6)
  version                Int                  @default(1)
  created_at             DateTime             @default(now()) @db.Timestamptz(6)
  updated_at             DateTime             @default(now()) @updatedAt @db.Timestamptz(6)
  decision_actions       DecisionAction[]
  snapshot               Snapshot             @relation(fields: [snapshot_id], references: [id])
  override_preferences   OverridePreference[]

  @@index([decision_status])
  @@map("decisions")
}

model DecisionAction {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  decision_id     String         @db.Uuid
  action          OperatorAction
  final_action    ActionType
  override_reason String?
  actor_user_id   String         @db.Uuid
  actor_role      String
  submitted_at    DateTime       @default(now()) @db.Timestamptz(6)
  source          ActionSource
  actor           User           @relation(fields: [actor_user_id], references: [id])
  decision        Decision       @relation(fields: [decision_id], references: [id])

  @@map("decision_actions")
}

model OverridePreference {
  id                     String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  decision_id            String     @db.Uuid
  snapshot_id            String     @db.Uuid
  ai_recommended_action  ActionType
  human_selected_action ActionType
  override_reason        String?
  confidence_gap         Float?
  created_at             DateTime   @default(now()) @db.Timestamptz(6)
  decision               Decision   @relation(fields: [decision_id], references: [id])

  @@map("override_preferences")
}

model AgentTranscript {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  snapshot_id      String           @db.Uuid
  round_no         Int
  agent_name       String
  message_type     AgentMessageType
  action_candidate ActionType?
  confidence       Float?
  reasoning_text   String
  created_at       DateTime         @default(now()) @db.Timestamptz(6)
  snapshot         Snapshot         @relation(fields: [snapshot_id], references: [id])

  @@index([snapshot_id, round_no, created_at])
  @@map("agent_transcripts")
}

model RuntimeConfig {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  config_group      ConfigGroup
  config_key        String      @unique
  config_value_json Json
  version_no        Int
  is_active         Boolean     @default(true)
  updated_by        String?     @db.Uuid
  updated_at        DateTime    @default(now()) @db.Timestamptz(6)
  updater           User?       @relation(fields: [updated_by], references: [id], onDelete: Restrict)

  @@map("runtime_configs")
}

model User {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username         String           @unique
  full_name        String?
  email            String?
  password_hash    String
  role             UserRole         @default(VIEWER)
  active           Boolean          @default(true)
  last_login_at    DateTime?        @db.Timestamptz(6)
  created_at       DateTime         @default(now()) @db.Timestamptz(6)
  updated_at       DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  audit_logs       AuditLog[]
  decision_actions DecisionAction[]
  runtime_configs  RuntimeConfig[]

  @@map("users")
}

model AuditLog {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entity_type   EntityType
  entity_id     String
  action        String
  actor_user_id String?    @db.Uuid
  payload_json  Json?
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  actor         User?      @relation(fields: [actor_user_id], references: [id], onDelete: Restrict)

  @@index([entity_type, entity_id])
  @@index([created_at(sort: Desc)])
  @@map("audit_logs")
}

enum BearingStatus {
  NORMAL
  INSPECT
  NEGOTIATE
  MAINTAIN
  STOP
  OFFLINE
}

enum FaultType {
  INNER_RACE
  OUTER_RACE
  BALL
  CAGE
  UNKNOWN
}

enum DecisionStatus {
  PENDING
  RESOLVED
  ACKNOWLEDGED
}

enum ActionType {
  CONTINUE
  INSPECT
  MAINTAIN
  STOP
}

enum OperatorAction {
  APPROVE
  OVERRIDE
  REJECT
  ACKNOWLEDGE
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TriggerSource {
  ANOMALY_TRIGGER
  SAFETY_VETO
  MANUAL_REQUEST
  SCHEDULED_CHECK
}

enum AgentMessageType {
  PROPOSE
  CRITIQUE
  VOTE
  SUMMARY
}

enum UserRole {
  VIEWER
  OPERATOR
  ENGINEER
  ADMIN
}

enum DecisionType {
  MAINTENANCE
  INSPECTION
  REPLACEMENT
  IGNORE
}

enum EntityType {
  DECISION
  CONFIG
  AUTH
  SYSTEM
}

enum ConfigGroup {
  THRESHOLDS
  AGENTS
  SYNTHETIC_CONTEXT
}

enum ActionSource {
  WEB_UI
  API
  SYSTEM
}
