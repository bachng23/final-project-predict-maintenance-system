generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Bearing {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bearingId        String        @unique @map("bearing_id")
  displayName      String        @map("display_name")
  datasetSource    String        @map("dataset_source")
  conditionLabel   String        @map("condition_label")
  rpm              Int?
  loadKn           Decimal?      @map("load_kn")
  installationDate DateTime?     @map("installation_date") @db.Timestamptz(6)
  status           BearingStatus @default(NORMAL)
  active           Boolean       @default(true)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  predictions      Prediction[]
  snapshots        Snapshot[]

  @@map("bearings")
}

model Prediction {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bearingId        String     @map("bearing_id") @db.Uuid
  fileIdx          Int        @map("file_idx")
  sampleTs         DateTime   @map("sample_ts") @db.Timestamptz(6)
  rulHours         Decimal    @map("rul_hours")
  rulLowerHours    Decimal?   @map("rul_lower_hours")
  rulUpperHours    Decimal?   @map("rul_upper_hours")
  pFail            Decimal    @map("p_fail")
  healthScore      Decimal    @map("health_score")
  uncertaintyScore Decimal?   @map("uncertainty_score")
  faultType        String?    @map("fault_type")
  faultConfidence  Decimal?   @map("fault_confidence")
  statScore        Decimal?   @map("stat_score")
  rulDropScore     Decimal?   @map("rul_drop_score")
  hybridScore      Decimal?   @map("hybrid_score")
  thresholdTau     Decimal?   @map("threshold_tau")
  modelVersion     String     @map("model_version")
  pipelineRunId    String?    @map("pipeline_run_id")
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  bearing          Bearing    @relation(fields: [bearingId], references: [id], onDelete: Cascade)
  snapshots        Snapshot[]

  @@unique([bearingId, fileIdx, modelVersion])
  @@index([bearingId, sampleTs(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("predictions")
}

model Snapshot {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bearingId        String            @map("bearing_id") @db.Uuid
  predictionId     String            @map("prediction_id") @db.Uuid
  snapshotTs       DateTime          @map("snapshot_ts") @db.Timestamptz(6)
  status           String
  triggerSource    TriggerSource     @map("trigger_source")
  featureVectorRef String?           @map("feature_vector_ref")
  signalWindowRef  String?           @map("signal_window_ref")
  summaryJson      Json?             @map("summary_json")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  agentTranscripts AgentTranscript[]
  decision         Decision?
  bearing          Bearing           @relation(fields: [bearingId], references: [id], onDelete: Cascade)
  prediction       Prediction        @relation(fields: [predictionId], references: [id], onDelete: Cascade)

  @@index([bearingId, snapshotTs(sort: Desc)])
  @@map("snapshots")
}

model Decision {
  id                    String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  snapshotId            String               @unique @map("snapshot_id") @db.Uuid
  decisionType          String               @map("decision_type")
  recommendedAction     String               @map("recommended_action")
  recommendedConfidence Decimal?             @map("recommended_confidence")
  decisionStatus        DecisionStatus       @default(PENDING) @map("decision_status")
  priority              PriorityLevel        @default(MEDIUM)
  safetyVeto            Boolean              @default(false) @map("safety_veto")
  reasonSummary         String?              @map("reason_summary")
  openedAt              DateTime             @default(now()) @map("opened_at") @db.Timestamptz(6)
  resolvedAt            DateTime?            @map("resolved_at") @db.Timestamptz(6)
  version               Int                  @default(1)
  createdAt             DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  decisionActions       DecisionAction[]
  snapshot              Snapshot             @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  overridePreferences   OverridePreference[]

  @@map("decisions")
}

model DecisionAction {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  decisionId     String         @map("decision_id") @db.Uuid
  action         OperatorAction
  finalAction    String         @map("final_action")
  overrideReason String?        @map("override_reason")
  actorUserId    String         @map("actor_user_id") @db.Uuid
  actorRole      String         @map("actor_role")
  submittedAt    DateTime       @default(now()) @map("submitted_at") @db.Timestamptz(6)
  source         String
  actor          User           @relation(fields: [actorUserId], references: [id])
  decision       Decision       @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@map("decision_actions")
}

model OverridePreference {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  decisionId          String   @map("decision_id") @db.Uuid
  snapshotId          String   @map("snapshot_id") @db.Uuid
  aiRecommendedAction String   @map("ai_recommended_action")
  humanSelectedAction String   @map("human_selected_action")
  overrideReason      String?  @map("override_reason")
  confidenceGap       Decimal? @map("confidence_gap")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  decision            Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@map("override_preferences")
}

model AgentTranscript {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  snapshotId      String           @map("snapshot_id") @db.Uuid
  roundNo         Int              @map("round_no")
  agentName       String           @map("agent_name")
  messageType     AgentMessageType @map("message_type")
  actionCandidate String?          @map("action_candidate")
  confidence      Decimal?         @map("confidence")
  reasoningText   String           @map("reasoning_text")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  snapshot        Snapshot         @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId, roundNo, createdAt])
  @@map("agent_transcripts")
}

model RuntimeConfig {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  configGroup     String   @map("config_group")
  configKey       String   @map("config_key")
  configValueJson Json     @map("config_value_json")
  versionNo       Int      @map("version_no")
  isActive        Boolean  @default(true) @map("is_active")
  updatedBy       String?  @map("updated_by") @db.Uuid
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  updater         User?    @relation(fields: [updatedBy], references: [id])

  @@map("runtime_configs")
}

model User {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username        String           @unique
  fullName        String?          @map("full_name")
  email           String?
  passwordHash    String           @map("password_hash")
  role            UserRole         @default(VIEWER)
  active          Boolean          @default(true)
  lastLoginAt     DateTime?        @map("last_login_at") @db.Timestamptz(6)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  auditLogs       AuditLog[]
  decisionActions DecisionAction[]
  runtimeConfigs  RuntimeConfig[]

  @@map("users")
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  action      String
  actorUserId String?  @map("actor_user_id") @db.Uuid
  payloadJson Json?    @map("payload_json")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  actor       User?    @relation(fields: [actorUserId], references: [id])

  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

enum BearingStatus {
  NORMAL
  INSPECT
  NEGOTIATE
  MAINTAIN
  STOP
  OFFLINE
}

enum DecisionStatus {
  PENDING
  RESOLVED
  ACKNOWLEDGED
}

enum OperatorAction {
  APPROVE
  OVERRIDE
  REJECT
  ACKNOWLEDGE
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TriggerSource {
  ANOMALY_TRIGGER
  SAFETY_VETO
  MANUAL_REQUEST
  SCHEDULED_CHECK
}

enum AgentMessageType {
  PROPOSE
  CRITIQUE
  VOTE
  SUMMARY
}

enum UserRole {
  VIEWER
  OPERATOR
  ENGINEER
  ADMIN
}
